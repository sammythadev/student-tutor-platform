NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
LOG_DRIVER=winston
LOG_ENABLED=true
LOG_FILE_PATH=logs/app.log
APP_NAME=student-tutor-matchmaking-backend
APP_VERSION=0.0.0
SWAGGER_PATH=api-docs
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>
######################################################################################
# AUTHENTICATION & SECURITY
######################################################################################
JWT_ACCESS_TOKEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-access-private-key\n-----END PRIVATE KEY-----"
JWT_ACCESS_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-access-public-key\n-----END PUBLIC KEY-----"
JWT_REFRESH_TOKEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-refresh-private-key\n-----END PRIVATE KEY-----"
JWT_REFRESH_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-refresh-public-key\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
ADMIN_SIGNUP_CODE=replace-with-admin-bootstrap-code
